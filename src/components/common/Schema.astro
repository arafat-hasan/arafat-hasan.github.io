---
/**
 * Structured Data Schema Component
 * Implements JSON-LD markup for SEO (Person, Website, Article, Breadcrumb)
 */

import { SITE_CONFIG, SOCIAL_LINKS } from "../../config/constants";

type SchemaType = "Person" | "Website" | "Article" | "BreadcrumbList";

interface Props {
    type: SchemaType;
    data?: any;
}

const { type, data = {} } = Astro.props;
const siteUrl = Astro.site?.toString() || SITE_CONFIG.url;
const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();

// Get metadata from centralized configuration
const siteTitle = SITE_CONFIG.title;
const siteDescription = SITE_CONFIG.description;

// Social profile URLs from centralized configuration
const socialProfiles = Object.values(SOCIAL_LINKS).map((link) => link.url);

// Person Schema (for homepage and about page)
const personSchema = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: SITE_CONFIG.name,
    alternateName: SITE_CONFIG.seo.alternateName,
    url: siteUrl,
    image: `${siteUrl}${SITE_CONFIG.seo.ogImage}`,
    jobTitle: SITE_CONFIG.seo.jobTitle,
    description: siteDescription,
    sameAs: socialProfiles,
    knowsAbout: SITE_CONFIG.seo.knowsAbout,
};

// Website Schema (for homepage)
const websiteSchema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteTitle,
    url: siteUrl,
    description: siteDescription,
    author: {
        "@type": "Person",
        name: SITE_CONFIG.name,
        alternateName: SITE_CONFIG.seo.alternateName,
    },
    inLanguage: SITE_CONFIG.seo.language,
};

// Article Schema (for blog posts)
const articleSchema = data.article
    ? {
          "@context": "https://schema.org",
          "@type": "Article",
          headline: data.article.title,
          description: data.article.description || data.article.excerpt,
          author: {
              "@type": "Person",
              name: SITE_CONFIG.name,
              alternateName: SITE_CONFIG.seo.alternateName,
              url: siteUrl,
          },
          datePublished: data.article.publishedAt,
          dateModified: data.article.updatedAt || data.article.publishedAt,
          image: data.article.image
              ? `${siteUrl}${data.article.image}`
              : `${siteUrl}${SITE_CONFIG.seo.ogImage}`,
          publisher: {
              "@type": "Person",
              name: SITE_CONFIG.name,
              logo: {
                  "@type": "ImageObject",
                  url: `${siteUrl}${SITE_CONFIG.seo.logo}`,
              },
          },
          mainEntityOfPage: {
              "@type": "WebPage",
              "@id": currentUrl,
          },
          keywords: data.article.tags?.join(", "),
          articleSection: data.article.category,
          inLanguage: SITE_CONFIG.seo.language,
      }
    : null;

// Breadcrumb Schema
const breadcrumbSchema = data.breadcrumbs
    ? {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          itemListElement: data.breadcrumbs.map(
              (crumb: any, index: number) => ({
                  "@type": "ListItem",
                  position: index + 1,
                  name: crumb.name,
                  item: `${siteUrl}${crumb.path}`,
              }),
          ),
      }
    : null;

// Select schema based on type
let schema;
switch (type) {
    case "Person":
        schema = personSchema;
        break;
    case "Website":
        schema = websiteSchema;
        break;
    case "Article":
        schema = articleSchema;
        break;
    case "BreadcrumbList":
        schema = breadcrumbSchema;
        break;
    default:
        schema = null;
}
---

{
    schema && (
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(schema)}
        />
    )
}
