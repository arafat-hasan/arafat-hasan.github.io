---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { SITE_CONFIG, SOCIAL_LINKS } from "../config/constants";
---

<BaseLayout
    title="Contact - Arafat Hasan"
    description="Get in touch with Arafat Hasan for software engineering consulting, technical writing, or professional inquiries."
>
    <Navbar slot="navbar" />

    <div class="max-w-2xl">
        <h1 class="text-3xl sm:text-4xl font-bold mb-6 sm:mb-8">
            Get In Touch
        </h1>

        <div class="space-y-6 text-gray-700">
            <p class="text-base sm:text-lg">
                I'm always interested in hearing about new opportunities,
                collaborations, or just having a chat about technology and
                software engineering.
            </p>

            <div class="space-y-4 mt-6 sm:mt-8">
                <h2 class="text-xl sm:text-2xl font-semibold text-gray-900">
                    Contact Information
                </h2>

                <div class="space-y-3">
                    <div
                        class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-3"
                    >
                        <span class="font-medium text-gray-900 sm:min-w-[80px]"
                            >Email:</span
                        >
                        <a
                            href={SITE_CONFIG.emailHref}
                            class="text-blue-600 hover:underline break-all touch-manipulation"
                        >
                            {SITE_CONFIG.email}
                        </a>
                    </div>

                    <div
                        class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-3"
                    >
                        <span class="font-medium text-gray-900 sm:min-w-[80px]"
                            >LinkedIn:</span
                        >
                        <a
                            href={SOCIAL_LINKS.linkedin.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-blue-600 hover:underline break-all touch-manipulation"
                        >
                            {SOCIAL_LINKS.linkedin.url.replace("https://", "")}
                        </a>
                    </div>
                </div>
            </div>

            <div class="mt-8 sm:mt-12 p-4 sm:p-6 bg-gray-50 rounded-lg">
                <h3 class="font-semibold text-gray-900 mb-2">
                    Preferred Contact Method
                </h3>
                <p class="text-gray-700 text-sm sm:text-base">
                    Email is the best way to reach me. I typically respond
                    within 24-48 hours. For urgent matters, please mention
                    "URGENT" in the subject line.
                </p>
            </div>

            <div class="mt-6 sm:mt-8">
                <h3 class="font-semibold text-gray-900 mb-3">Find Me Online</h3>
                <div
                    class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2"
                >
                    <a
                        href={SOCIAL_LINKS.github.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-center"
                    >
                        <span class="font-medium text-gray-900"
                            >{SOCIAL_LINKS.github.name}</span
                        >
                    </a>

                    <a
                        href={SOCIAL_LINKS.linkedin.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-center"
                    >
                        <span class="font-medium text-gray-900"
                            >{SOCIAL_LINKS.linkedin.name}</span
                        >
                    </a>

                    <a
                        href={SOCIAL_LINKS.stackoverflow.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-center"
                    >
                        <span class="font-medium text-gray-900"
                            >{SOCIAL_LINKS.stackoverflow.name}</span
                        >
                    </a>

                    <a
                        href={SOCIAL_LINKS.substack.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-center"
                    >
                        <span class="font-medium text-gray-900"
                            >{SOCIAL_LINKS.substack.name}</span
                        >
                    </a>

                    <a
                        href={SOCIAL_LINKS.x.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="p-3 bg-gray-50 hover:bg-gray-100 rounded-lg transition-colors text-center"
                    >
                        <span class="font-medium text-gray-900"
                            >{SOCIAL_LINKS.x.name}</span
                        >
                    </a>
                </div>
            </div>

            <div class="mt-6 sm:mt-8">
                <h3 class="font-semibold text-gray-900 mb-3">
                    What I'm interested in:
                </h3>
                <ul
                    class="list-disc pl-5 sm:pl-6 space-y-2 text-gray-700 text-sm sm:text-base"
                >
                    <li>Software engineering opportunities</li>
                    <li>Open-source collaborations</li>
                    <li>Technical consulting</li>
                    <li>Speaking engagements or podcast appearances</li>
                    <li>Interesting technical challenges</li>
                </ul>
            </div>
        </div>
    </div>

    <Footer slot="footer" />
</BaseLayout>
